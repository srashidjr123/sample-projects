# Copy to .env and fill in real values for local runs.
# These environment variables replace the credentials that lived
# in the notebooks before sanitization.

# Working / data directories (Databricks DBFS replacements)
DATA_DIR=./data
WORK_DIR=./work

# WP Engine SFTP for nam.org partial / JSON uploads (project 01, 02, 03)
FTP_HOST=
FTP_USER=
FTP_PASS=

# Google Maps geocoding (project 05)
GOOGLE_MAPS_API_KEY=

# WP-All-Import trigger key (projects 01, 02, 05)
WP_IMPORT_KEY=
